generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Campaign {
  id                       String         @id @default(uuid())
  name                     String
  industry                 String
  clientCompanyName        String
  subcontractorCompanyName String
  markupPercentage         Float
  commissionPercentage     Float
  clientMarginPercentage   Float
  status                   CampaignStatus @default(ACTIVE)
  startDate                DateTime
  sandbox_active           Boolean        @default(false) // sandbox mode active — test lead exists
  customer_from_email      String?        // e.g. "hello@continuousgroup.co.nz" — sender address for customer emails
  customer_from_name       String?        // e.g. "Continuous Group" — display name shown to customers in their inbox
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt

  users                     User[]
  leads                     Lead[]
  auditLogs                 AuditLog[]
  attachments               Attachment[]
  reconciliationBatches     ReconciliationBatch[]
  jobTypes                  JobType[]
  availabilitySlots         AvailabilitySlot[]
  billing_profiles          BillingProfile[]
  customer_payment_profiles CustomerPaymentProfile[]
}

model User {
  id                    String    @id @default(uuid())
  name                  String
  email                 String    @unique
  passwordHash          String
  role                  Role
  campaignId            String?
  isActive              Boolean   @default(true)
  lastLoginAt           DateTime?
  notifyNewLead                Boolean   @default(true)
  notifyJobCompleted           Boolean   @default(true)
  invoice_reminder_day         Int?      // day of month (1–28) to receive reminder email; null = no reminder
  invoice_auto_send            Boolean   @default(false) // if true, auto-send invoice on reminder day instead of emailing admin
  notify_payment_reminder      Boolean   @default(true)  // ADMIN only — send Day 5 customer payment reminder
  notify_payment_overdue       Boolean   @default(true)  // ADMIN only — send Day 7 overdue alert to Oli
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  campaign                  Campaign?             @relation(fields: [campaignId], references: [id])
  auditLogs                 AuditLog[]
  attachments               Attachment[]
  passwordResetTokens       PasswordResetToken[]
  customer_payment_profile  CustomerPaymentProfile?
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model JobType {
  id              String   @id @default(uuid())
  campaignId      String
  name            String
  durationMinutes Int
  sortOrder       Int
  createdAt       DateTime @default(now())

  campaign Campaign  @relation(fields: [campaignId], references: [id])
  leads    Lead[]
}

model Lead {
  id                    String     @id @default(uuid())
  campaignId            String
  quoteNumber           String     @unique
  customerName          String
  customerPhone         String
  customerEmail         String?
  propertyAddress       String
  googleMapsUrl         String
  propertyPerimeterM    Float?
  propertyAreaM2        Float?
  propertyStoreys       Int?
  gutter_guards         String?   // "Yes" or "No" — whether the property has gutter guards installed
  storey_count          String?   // "1", "2", or "Unsure" — number of storeys on the property
  contractorRate        Float?
  customerPrice         Float?
  grossMarkup           Float?
  omnisideCommission    Float?
  clientMargin          Float?
  status                LeadStatus @default(LEAD_RECEIVED)
  source                String     @default("n8n_webhook")
  webhookRaw            String?
  invoiceUrl            String?
  invoiceUploadedAt     DateTime?
  invoiceUploadedById   String?
  quoteUrl              String?
  quoteUploadedAt       DateTime?
  quoteUploadedBy       String?
  bookingToken          String?    @unique
  jobTypeId             String?
  jobBookedDate         DateTime?
  jobCompletedAt        DateTime?
  jobReportUrl          String?
  jobReportUploadedAt   DateTime?
  jobReportUploadedBy   String?
  customerPortalToken      String?   @unique
  customerEmailSentAt      DateTime?
  stripeCheckoutUrl        String?
  invoiceTotalGstInclusive Float?    // GST-inclusive total extracted by AI at Submit Job — used as Stripe charge amount
  customer_paid_at             DateTime? // Set by Stripe webhook when checkout.session.completed fires
  stripe_payment_intent        String?   // Stripe PaymentIntent ID — set alongside customer_paid_at
  payment_reminder_sent_at     DateTime? // Timestamp when the Day 5 reminder was sent to the customer
  payment_overdue_alerted_at   DateTime? // Timestamp when the Day 7 alert was sent to Oli
  myob_invoice_id              String?   // MYOB invoice UID — set when MYOB invoice is created on job completion
  myob_invoice_url             String?   // MYOB hosted invoice URL for homeowner payment
  myob_invoice_created_at      DateTime? // Timestamp when MYOB invoice was created
  stripe_customer_payment_url  String?   // New Stripe Checkout URL (distinct from legacy stripeCheckoutUrl)
  reconciliationBatchId String?
  notes                 String?
  internal_notes        String?
  quoteOptions                Json?      // Array of AI-parsed quote options — see ParsedQuoteOption in lib/parseQuotePdf.ts
  quoteValidationOverridden   Boolean?   @default(false)
  needsReview                 Boolean    @default(false)
  duplicate_dismissed         Boolean    @default(false)
  duplicate_confidence        String?    // 'high' or 'medium' — null if no duplicate found
  duplicate_reason            String?    // e.g. "Same phone number and address"
  duplicate_lead_id           String?    // quote_number of the matched lead
  cancellation_reason   String?    // Set when lead is marked as Job Cancelled
  not_converted_reason  String?    // Optional reason recorded when lead is marked NOT_CONVERTED
  is_test               Boolean    @default(false) // sandbox test lead — not visible to CLIENT/SUBCONTRACTOR
  customer_payment_method String?  // 'card' | 'bank_transfer' — set when checkout is created
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  campaign             Campaign              @relation(fields: [campaignId], references: [id])
  reconciliationBatch  ReconciliationBatch?  @relation(fields: [reconciliationBatchId], references: [id])
  jobType              JobType?              @relation(fields: [jobTypeId], references: [id])
  auditLogs            AuditLog[]
  attachments          Attachment[]
  booking              Booking?
}

model ReconciliationBatch {
  id                   String    @id @default(uuid())
  campaignId           String
  label                String
  monthKeys            String
  totalJobs            Int
  totalContractorCost  Float
  totalCustomerRevenue Float
  totalCommission      Float
  reconciled           Boolean   @default(false)
  reconciledAt         DateTime?
  stripe_invoice_id         String?   // admin → client invoice ID (populated once sent)
  invoice_sent_at           DateTime? // timestamp when admin invoice was sent
  invoice_sent_by           String?   // user ID of admin who pressed "Confirm & Send"
  client_stripe_invoice_id  String?   // client → subcontractor invoice ID
  client_invoice_sent_at    DateTime? // timestamp when client invoice was sent
  client_invoice_sent_by    String?   // user ID of client who pressed "Confirm & Send"
  createdAt                 DateTime  @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id])
  leads    Lead[]
}

model AuditLog {
  id              String     @id @default(uuid())
  leadId          String
  campaignId      String
  changedByUserId String
  changedByName   String
  oldStatus       LeadStatus
  newStatus       LeadStatus
  createdAt       DateTime   @default(now())

  lead     Lead     @relation(fields: [leadId], references: [id])
  campaign Campaign @relation(fields: [campaignId], references: [id])
  user     User     @relation(fields: [changedByUserId], references: [id])
}

model Attachment {
  id               String         @id @default(uuid())
  leadId           String
  campaignId       String
  uploadedByUserId String
  fileName         String
  fileType         String
  fileUrl          String
  fileSizeBytes    Int
  attachmentType   AttachmentType @default(INVOICE)
  createdAt        DateTime       @default(now())

  lead       Lead     @relation(fields: [leadId], references: [id])
  campaign   Campaign @relation(fields: [campaignId], references: [id])
  uploadedBy User     @relation(fields: [uploadedByUserId], references: [id])
}


model AvailabilitySlot {
  id         String   @id @default(uuid())
  campaignId String
  date       DateTime
  startTime  String   // "07:00"
  endTime    String   // "13:00"
  notes      String?
  createdAt  DateTime @default(now())

  campaign Campaign  @relation(fields: [campaignId], references: [id])
  bookings Booking[]
}

model Booking {
  id           String        @id @default(uuid())
  slotId       String
  leadId       String        @unique
  windowStart  String        // "07:00"
  windowEnd    String        // "09:00"
  bookedAt     DateTime      @default(now())
  heldUntil    DateTime?
  heldByToken  String?
  status       BookingStatus @default(HELD)

  slot AvailabilitySlot @relation(fields: [slotId], references: [id])
  lead Lead             @relation(fields: [leadId], references: [id])
}

model CustomerPaymentProfile {
  id          String    @id @default(cuid())
  campaign_id String                        // no longer @unique — multiple profiles per campaign allowed
  user_id     String?   @unique             // which client user owns this profile
  is_active   Boolean   @default(false)     // only one per campaign can be true at any time
  provider    String    // 'STRIPE' | 'MYOB' — string not enum for extensibility

  // Stripe fields (populated when provider = 'STRIPE', nulled when switching away)
  stripe_secret_key       String?   // AES-256 encrypted
  stripe_webhook_secret   String?   // AES-256 encrypted

  // MYOB fields (populated when provider = 'MYOB', nulled when switching away)
  myob_company_file_id    String?
  myob_access_token       String?   // AES-256 encrypted
  myob_refresh_token      String?   // AES-256 encrypted
  myob_token_expiry       DateTime?

  // Common
  verified      Boolean   @default(false)
  verified_at   DateTime?
  connected_at  DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  campaign      Campaign  @relation(fields: [campaign_id], references: [id])
  user          User?     @relation(fields: [user_id], references: [id])
}

model BillingProfile {
  id                    String    @id @default(uuid())
  campaign_id           String
  campaign              Campaign  @relation(fields: [campaign_id], references: [id])
  company_name          String
  billing_email         String
  billing_address       String?
  stripe_customer_id    String?   // required for ADMIN invoicing flow; null for CLIENT payment_only flow
  stripe_secret_key     String    // encrypted at rest — never stored plain text
  stripe_webhook_secret String?   // AES-256 encrypted — same pattern as stripe_secret_key
  stripe_gst_rate_id    String?   // required for ADMIN invoicing flow; null for CLIENT payment_only flow
  stripe_verified       Boolean   @default(false)
  stripe_verified_at    DateTime?
  role                  String    // "ADMIN" | "CLIENT"
  created_at            DateTime  @default(now())

  @@unique([campaign_id, role])
}

enum Role {
  ADMIN
  CLIENT
  SUBCONTRACTOR
}

enum LeadStatus {
  LEAD_RECEIVED
  QUOTE_SENT        // retained for legacy data — not used in new flow
  JOB_BOOKED
  JOB_COMPLETED
  JOB_CANCELLED     // exit state — lead will not proceed further
  NOT_CONVERTED     // exit state — lead was contacted but did not proceed to booking
}

enum CampaignStatus {
  ACTIVE
  PAUSED
  COMPLETED
}

enum AttachmentType {
  INVOICE
  JOB_REPORT
}

enum BookingStatus {
  HELD
  CONFIRMED
}
