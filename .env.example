DATABASE_URL="file:./dev.db"

NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

WEBHOOK_SECRET=""

RESEND_API_KEY=""
EMAIL_FROM="Jobbly <notifications@yourdomain.com>"
EMAIL_FRANK=""
EMAIL_OLI=""

UPLOAD_DIR="./uploads"

# Production S3-compatible storage
# S3_BUCKET=""
# S3_REGION=""
# S3_ACCESS_KEY=""
# S3_SECRET_KEY=""
# S3_ENDPOINT=""
ANTHROPIC_API_KEY=

ENCRYPTION_KEY=        # base64-encoded 32-byte random string — used to encrypt Stripe secret keys at rest
CRON_SECRET=           # random secret used to authenticate Vercel cron requests
STRIPE_WEBHOOK_SECRET= # Stripe webhook signing secret (whsec_...) — from Stripe Dashboard → Developers → Webhooks

GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# MYOB Developer App credentials — registered at developer.myob.com by Oli
# These are Jobbly's app credentials, NOT the client's credentials
MYOB_CLIENT_ID=
MYOB_CLIENT_SECRET=
MYOB_REDIRECT_URI=
# Must be: https://jobbly.nz/api/myob/callback
